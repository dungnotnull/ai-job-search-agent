# ── LLM API Keys ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Ollama (offline/privacy mode) ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Model overrides ────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o

# ── Privacy mode — set to true to disable all external API calls ───────────────
# When enabled: Ollama is used for LLM; HuggingFace models load from local cache
PRIVACY_MODE=false

# ── HuggingFace (optional — for private model access) ─────────────────────────
HUGGINGFACE_TOKEN=your_hf_token_here_if_needed

# ── App settings ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
PORT=8017
HOST=0.0.0.0

# ── Data paths ─────────────────────────────────────────────────────────────────
DATA_DIR=./data
MODELS_DIR=./models
